# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema
# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# [Database]
# **IMPORTANT**: Your database must support the PostGIS extension.
# If you don't use Docker, set up a Supabase or Vercel Postgres instance and get the URL here.
DATABASE_URL="postgresql://user:password@hostname:5432/db_name?schema=public"
DIRECT_URL="postgresql://user:password@hostname:5432/db_name?schema=public"

# [NextAuth]
# Used to encrypt session tokens
NEXTAUTH_SECRET="some-random-secret-string-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# [Map]
# MapLibre doesn't typically require a token for free OSM tiles, 
# but if you use Mapbox tiles or specific APIs:
NEXT_PUBLIC_MAPBOX_TOKEN=""

# [AWS / S3 Storage] (For photos in reviews)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET_NAME="museum-map-uploads"

# [Analytics]
NEXT_PUBLIC_GA_ID=""

# [AI / Search]
GEMINI_API_KEY=""
SERPER_API_KEY=""

# [Admin]
ADMIN_PASSWORD=""
SUPER_ADMIN_PASSWORD=""

# [Supabase]
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# [Europeana Open Access API]
# Free API key — sign up at https://pro.europeana.eu/pages/get-api
EUROPEANA_API_KEY=""
